<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporanMahasiswa"
              pageWidth="595" pageHeight="842"
              orientation="Portrait"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="30" bottomMargin="30">

    <parameter name="judul" class="java.lang.String"/>

    <queryString>
        <![CDATA[SELECT nim, nama, semester, kelas FROM datamhs ORDER BY nama ASC]]>
    </queryString>

    <field name="nim"      class="java.lang.String"/>
    <field name="nama"     class="java.lang.String"/>
    <field name="semester" class="java.lang.Integer"/>
    <field name="kelas"    class="java.lang.String"/>

    <title>
        <band height="78">
            <staticText>
                <reportElement x="0" y="0" width="535" height="22"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[UNIVERSITAS PAMULANG]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="24" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="11" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{judul}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="44" width="535" height="14"/>
                <textElement textAlignment="Center">
                    <font size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Jl. Surya Kencana No. 1, Pamulang, Tangerang Selatan, Banten]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="70" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <staticText>
                <reportElement x="0" y="0" width="40" height="24" backcolor="#2E5C8A" mode="Opaque" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#FFFFFF"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[No]]></text>
            </staticText>
            <staticText>
                <reportElement x="40" y="0" width="110" height="24" backcolor="#2E5C8A" mode="Opaque" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#FFFFFF"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[NIM]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="0" width="230" height="24" backcolor="#2E5C8A" mode="Opaque" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#FFFFFF"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Nama Mahasiswa]]></text>
            </staticText>
            <staticText>
                <reportElement x="380" y="0" width="75" height="24" backcolor="#2E5C8A" mode="Opaque" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#FFFFFF"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Semester]]></text>
            </staticText>
            <staticText>
                <reportElement x="455" y="0" width="80" height="24" backcolor="#2E5C8A" mode="Opaque" forecolor="#FFFFFF"/>
                <box><pen lineWidth="0.5" lineColor="#FFFFFF"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Kelas]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="20" backcolor="#EEF3F8" mode="Opaque">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="0" width="40" height="20"/>
                <box leftPadding="3" rightPadding="3"><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="40" y="0" width="110" height="20"/>
                <box leftPadding="5" rightPadding="3"><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nim}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="150" y="0" width="230" height="20"/>
                <box leftPadding="5" rightPadding="3"><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="380" y="0" width="75" height="20"/>
                <box leftPadding="3" rightPadding="3"><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{semester}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="455" y="0" width="80" height="20"/>
                <box leftPadding="3" rightPadding="3"><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{kelas}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <columnFooter>
        <band height="28">
            <line>
                <reportElement x="0" y="2" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#2E5C8A"/>
                </graphicElement>
            </line>
            <staticText>
                <reportElement x="0" y="6" width="110" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Mahasiswa:]]></text>
            </staticText>
            <textField>
                <reportElement x="110" y="6" width="80" height="18"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </columnFooter>

    <pageFooter>
        <band height="22">
            <line>
                <reportElement x="0" y="0" width="535" height="1"/>
                <graphicElement>
                    <pen lineWidth="0.5" lineColor="#999999"/>
                </graphicElement>
            </line>
            <textField pattern="dd MMMM yyyy HH:mm">
                <reportElement x="0" y="4" width="300" height="14"/>
                <textElement>
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="335" y="4" width="200" height="14"/>
                <textElement textAlignment="Right">
                    <font size="7"/>
                </textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
