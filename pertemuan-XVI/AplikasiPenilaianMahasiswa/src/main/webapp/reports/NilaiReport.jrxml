<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="NilaiReport"
              pageWidth="842" pageHeight="595"
              orientation="Landscape"
              columnWidth="782" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <parameter name="REPORT_TITLE" class="java.lang.String"/>

    <queryString>
        <![CDATA[
            SELECT m.nim, m.nama, m.semester, m.kelas,
                   mk.kode_mk, mk.nama_mk, mk.sks,
                   n.nilai_tugas, n.nilai_uts, n.nilai_uas,
                   n.nilai_akhir, n.grade
            FROM tbnilai n
            JOIN tbmahasiswa  m  ON n.nim     = m.nim
            JOIN tbmatakuliah mk ON n.kode_mk = mk.kode_mk
            ORDER BY m.kelas ASC, m.nim ASC, mk.kode_mk ASC
        ]]>
    </queryString>

    <field name="nim"          class="java.lang.String"/>
    <field name="nama"         class="java.lang.String"/>
    <field name="semester"     class="java.lang.Integer"/>
    <field name="kelas"        class="java.lang.String"/>
    <field name="kode_mk"      class="java.lang.String"/>
    <field name="nama_mk"      class="java.lang.String"/>
    <field name="sks"          class="java.lang.Integer"/>
    <field name="nilai_tugas"  class="java.lang.Double"/>
    <field name="nilai_uts"    class="java.lang.Double"/>
    <field name="nilai_uas"    class="java.lang.Double"/>
    <field name="nilai_akhir"  class="java.lang.Double"/>
    <field name="grade"        class="java.lang.String"/>

    <!-- Nomor urut yang reset di tiap mahasiswa -->
    <variable name="noUrut" class="java.lang.Integer" resetType="Group" resetGroup="GrupMahasiswa" calculation="Count">
        <variableExpression><![CDATA[Boolean.TRUE]]></variableExpression>
    </variable>

    <!-- Grup berdasarkan Kelas: tampilkan Semester & Kelas -->
    <group name="GrupKelas">
        <groupExpression><![CDATA[$F{kelas}]]></groupExpression>
        <groupHeader>
            <band height="40">
                <staticText>
                    <reportElement x="0" y="5" width="60" height="15"/>
                    <text><![CDATA[Semester]]></text>
                </staticText>
                <textField>
                    <reportElement x="60" y="5" width="200" height="15"/>
                    <textFieldExpression><![CDATA[": " + $F{semester}]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="0" y="20" width="60" height="15"/>
                    <text><![CDATA[Kelas]]></text>
                </staticText>
                <textField>
                    <reportElement x="60" y="20" width="200" height="15"/>
                    <textFieldExpression><![CDATA[": " + $F{kelas}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <!-- Grup berdasarkan Mahasiswa: tampilkan NIM, Nama, dan header tabel -->
    <group name="GrupMahasiswa">
        <groupExpression><![CDATA[$F{nim}]]></groupExpression>
        <groupHeader>
            <band height="55">
                <staticText>
                    <reportElement x="0" y="2" width="60" height="15"/>
                    <text><![CDATA[NIM]]></text>
                </staticText>
                <textField>
                    <reportElement x="60" y="2" width="300" height="15"/>
                    <textFieldExpression><![CDATA[": " + $F{nim}]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="0" y="17" width="60" height="15"/>
                    <text><![CDATA[Nama]]></text>
                </staticText>
                <textField>
                    <reportElement x="60" y="17" width="500" height="15"/>
                    <textFieldExpression><![CDATA[": " + $F{nama}]]></textFieldExpression>
                </textField>

                <!-- Header kolom tabel -->
                <staticText>
                    <reportElement x="0" y="35" width="35" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[No.]]></text>
                </staticText>
                <staticText>
                    <reportElement x="35" y="35" width="90" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Kode Mata Kuliah]]></text>
                </staticText>
                <staticText>
                    <reportElement x="125" y="35" width="277" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Nama Mata Kuliah]]></text>
                </staticText>
                <staticText>
                    <reportElement x="402" y="35" width="40" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[SKS]]></text>
                </staticText>
                <staticText>
                    <reportElement x="442" y="35" width="50" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Tugas]]></text>
                </staticText>
                <staticText>
                    <reportElement x="492" y="35" width="50" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[UTS]]></text>
                </staticText>
                <staticText>
                    <reportElement x="542" y="35" width="50" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[UAS]]></text>
                </staticText>
                <staticText>
                    <reportElement x="592" y="35" width="70" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Nilai Akhir]]></text>
                </staticText>
                <staticText>
                    <reportElement x="662" y="35" width="40" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Huruf]]></text>
                </staticText>
                <staticText>
                    <reportElement x="702" y="35" width="80" height="20" backcolor="#E6E6E6" mode="Opaque"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle"><font isBold="true" size="8"/></textElement>
                    <text><![CDATA[Status]]></text>
                </staticText>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="8"/>
        </groupFooter>
    </group>

    <!-- Judul laporan -->
    <pageHeader>
        <band height="70">
            <staticText>
                <reportElement x="0" y="0" width="782" height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <text><![CDATA[LAPORAN NILAI MAHASISWA]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="20" width="782" height="22"/>
                <textElement textAlignment="Center"><font size="15" isBold="true"/></textElement>
                <text><![CDATA[UNIVERSITAS PAMULANG]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="42" width="782" height="16"/>
                <textElement textAlignment="Center"><font size="8"/></textElement>
                <text><![CDATA[Jl. Surya Kencana No. 1 Pamulang, Tangerang Selatan, Banten]]></text>
            </staticText>
        </band>
    </pageHeader>

    <!-- Baris data per mata kuliah -->
    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="35" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$V{noUrut}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="35" y="0" width="90" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{kode_mk}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="125" y="0" width="277" height="18"/>
                <box leftPadding="4"><pen lineWidth="0.5"/></box>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{nama_mk}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="402" y="0" width="40" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{sks}]]></textFieldExpression>
            </textField>
            <textField pattern="##0">
                <reportElement x="442" y="0" width="50" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{nilai_tugas}]]></textFieldExpression>
            </textField>
            <textField pattern="##0">
                <reportElement x="492" y="0" width="50" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{nilai_uts}]]></textFieldExpression>
            </textField>
            <textField pattern="##0">
                <reportElement x="542" y="0" width="50" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{nilai_uas}]]></textFieldExpression>
            </textField>
            <textField pattern="##0.00">
                <reportElement x="592" y="0" width="70" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{nilai_akhir}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="662" y="0" width="40" height="18"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{grade}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="702" y="0" width="80" height="18"/>
                <box leftPadding="4"><pen lineWidth="0.5"/></box>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[($F{grade}.equals("D") || $F{grade}.equals("E")) ? "Tidak Lulus" : "Lulus"]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="782" height="20"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>
